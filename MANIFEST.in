prune .pytest_cache
prune .ruff_cache
prune .mypy_cache
prune .pyright
prune .agents
prune .codex
prune .idea
prune .vscode
prune .venv*
prune venv
prune env
prune ENV
prune benchmarks/data/generated
prune benchmarks/output
prune benchmarks/results
prune benchmarks/profiles
prune build
prune dist
prune htmlcov
prune reports
prune generated-reports
prune validation-output
prune validation-results
prune output
prune logs
prune tmp_*
prune *.egg-info

global-exclude __pycache__
global-exclude *.py[cod]
global-exclude *.prof
global-exclude *.log
global-exclude *.statconvert-metadata.json
global-exclude .coverage
global-exclude .coverage.*
global-exclude coverage.xml
global-exclude .DS_Store
global-exclude Thumbs.db
